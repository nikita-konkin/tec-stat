# Copy this file to .env and adjust for your environment.
# All keys map directly to fields in app/config.py.

# ── Data paths ────────────────────────────────────────────────────────────────
#
# Option A — both datasets share one directory tree:
#
#   DATA_ROOT=/archive/gnss
#
# This is the simplest setup.  A single root is used for both AbsolTEC
# and TEC-suite queries.  The directory must contain {year}_parq/ subdirs.
#
DATA_ROOT=/data

# Option B — datasets live in separate directories:
#
# Set these to override DATA_ROOT for each product independently.
# Leave the lines commented out (or empty) to fall back to DATA_ROOT.
#
#   ABSOLTEC_DATA_ROOT=/mnt/nas/absoltec
#   TEC_DATA_ROOT=/mnt/fast-ssd/tec-suite
#
# You can also mix them: set DATA_ROOT as a default and override only one:
#
#   DATA_ROOT=/data
#   TEC_DATA_ROOT=/mnt/fast-ssd/tec-suite   # TEC on fast disk, AbsolTEC on /data
#
ABSOLTEC_DATA_ROOT=
TEC_DATA_ROOT=

# Priority (highest first):
#   1. ABSOLTEC_DATA_ROOT / TEC_DATA_ROOT  (product-specific, always wins if non-empty)
#   2. DATA_ROOT                           (shared fallback)
#   3. Built-in defaults /data/absoltec and /data/tec

# ── Statistics ────────────────────────────────────────────────────────────────
DEFAULT_ALPHA=0.05          # significance level for Student-t CI (0.05 = 95 %)

# ── Plots ─────────────────────────────────────────────────────────────────────
PLOT_DPI=100
PLOT_WIDTH_PX=1200
PLOT_HEIGHT_PX=600
SAVGOL_POLYNOMIAL_ORDER=3

# ── API ───────────────────────────────────────────────────────────────────────
API_PREFIX=                 # set to /api/v1 when running behind a reverse proxy

# ── Server ────────────────────────────────────────────────────────────────────
WORKERS=2
LOG_LEVEL=info
